##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
##############################################################################

# NOTE: this repo keeps an independent wrapper for each module.

DIR="$(cd "$(dirname "$0")" && pwd)"

java_exec() {
  if [ -n "$JAVA_HOME" ] && [ -x "$JAVA_HOME/bin/java" ]; then
    echo "$JAVA_HOME/bin/java"
  else
    echo "java"
  fi
}

# Load wrapper JAR
WRAPPER_JAR="$DIR/gradle/wrapper/gradle-wrapper.jar"

if [ ! -f "$WRAPPER_JAR" ]; then
  echo "Gradle wrapper JAR not found at $WRAPPER_JAR" >&2
  echo "Copy it from ai-meal-assistant-backend/gradle/wrapper or run gradle wrapper in this module." >&2
  exit 1
fi

exec "$(java_exec)" -classpath "$WRAPPER_JAR" org.gradle.wrapper.GradleWrapperMain "$@"
